{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Koin",
  "version": "0.1.0",
  "identifier": "Koin",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Koin",
        "label": "main",
        "width": 1600,
        "height": 1080,
        "visible": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "center": true,
        "trafficLightPosition": {
          "x": 12,
          "y": 20
        }
      },
      {
        "title": "Koin",
        "label": "splashscreen",
        "url": "splashscreen.html",
        "width": 1600,
        "height": 1080,
        "decorations": false,
        "titleBarStyle": "Overlay",
        "transparent": true,
        "center": true,
        "resizable": false,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/coin_images/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/issuers.json"]
  }
}
